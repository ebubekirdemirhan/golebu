# football-data.org — canlı maçlar (birincil kaynak)
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# API-Football (api-sports.io) — ikincil fikstür: TFF 1./2., Suudi, BAE, Katar vb.
# Ücretsiz plan günlük istek limiti düşüktür. https://www.api-football.com/
API_FOOTBALL_KEY=your_api_football_key_here
# İsteğe bağlı: virgülle lig ID’leri (varsayılan: 204=Süper Lig, 205,206,307,301,233)
# API_FOOTBALL_LEAGUE_IDS=204,205,206,307,301,233

# Google Gemini — AI asistan (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# NextAuth (Vercel’de NEXTAUTH_URL = https://domainin.vercel.app)
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# İsteğe bağlı: Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# İsteğe bağlı: Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
