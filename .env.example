# football-data.org — canlı maçlar (birincil kaynak)
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# API-Football (api-sports.io) — ikincil fikstür: TFF 1./2., Suudi, BAE, Katar vb.
# Ücretsiz plan günlük istek limiti düşüktür. https://www.api-football.com/
API_FOOTBALL_KEY=your_api_football_key_here
# İsteğe bağlı: virgülle lig ID’leri (varsayılan: 203=Süper Lig, 204=TFF1, 205=TFF2, 307,301,305)
# API_FOOTBALL_LEAGUE_IDS=203,204,205,307,301,305
# İsteğe bağlı: günlük kart sayısı ve kaynak kotası
# MAX_MATCHES=20
# MAX_SECONDARY=8
# ESPN lig bazlı scrape için üst kota (API-Football’tan bağımsız)
# MAX_SCRAPE=35
# ESPN çekim penceresi = MATCH_DAYS_AHEAD + ek gün (hafta sonu fikstürü için)
# SCRAPE_INCLUDE_PAST_DAYS=1
# SCRAPE_EXTRA_DAYS_AHEAD=14
# Scrape: virgülle ESPN slug listesi; yoksa varsayılan 20+ lig (eng.1,tur.1,uefa.champions,…)
# SCRAPE_LEAGUES=eng.1,tur.1,esp.1
# Scrape fallback ve kaynak orkestrasyonu
# ENABLE_SCRAPING=true
# SOURCE_TIMEOUT_MS=9000
# SOURCE_RETRY_COUNT=2
# SCRAPE_TIMEOUT_MS=28000
# ESPN: her lig için tarihsiz + hafta sonu / hafta içi ?dates= taraması (istek sayısı artar)
# ESPN_SCOREBOARD_WEEKEND_WEEKS=5
# ESPN_SCRAPE_LEAGUE_CONCURRENCY=4

# Google Gemini — AI asistan (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# NextAuth (Vercel’de NEXTAUTH_URL = https://domainin.vercel.app)
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# İsteğe bağlı: Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# İsteğe bağlı: Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
